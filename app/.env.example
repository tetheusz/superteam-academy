# ──────────────────────────────────────────────
# Superteam Academy — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values

# ── Solana ─────────────────────────────────────
# RPC endpoint (defaults to Devnet if not set)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# On-chain program ID
NEXT_PUBLIC_PROGRAM_ID=ACADBRCB3zGvo1KSCbkztS33ZNzeBv2d7bqGceti3ucf

# XP Token-2022 mint address (set when deployed)
# NEXT_PUBLIC_XP_MINT_ADDRESS=

# ── Helius API (for credential/NFT queries) ────
# NEXT_PUBLIC_HELIUS_API_KEY=your_helius_api_key

# ── Auth (NextAuth.js) ─────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Site ───────────────────────────────────────
# Used for metadataBase (OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
